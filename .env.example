# Server
PORT=3000
NODE_ENV=development
SESSION_SECRET=change-me-to-a-long-random-string-at-least-32-chars-in-prod
SESSION_MAX_AGE_MS=604800000
TRUST_PROXY=0
CORS_ORIGIN=http://localhost:3000
APP_NAME=PGPT Secured
APP_ORIGIN=http://localhost:3000

# Optional: run migrations/001_secured_schema.sql automatically on startup
RUN_MIGRATIONS_ON_START=false

# First admin (only if no admin exists yet). Password must meet policy (12+ chars, mixed case, digit, symbol).
BOOTSTRAP_ADMIN_EMAIL=admin@example.com
BOOTSTRAP_ADMIN_PASSWORD=

# Registration (set to false to disable /auth/register)
ALLOW_PUBLIC_REGISTRATION=true

# MFA secret encryption (optional; falls back to SHA-256(SESSION_SECRET) — use 16+ char SESSION in dev)
MFA_ENCRYPTION_KEY=

# Rate limits (optional overrides)
# RATE_LIMIT_AUTH_WINDOW_MS=
# RATE_LIMIT_LOGIN_MAX=
# RATE_LIMIT_UPLOAD_MAX=

# Botpress (existing)
BOTPRESS_BOT_ID=
BOTPRESS_API_KEY=
BOTPRESS_KB_ID=

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

DB_HOST=localhost
DB_PORT=5432
DB_USER=judo_user
DB_PASSWORD=judo_pass
DB_NAME=judo_db

# Optional Firebase (mirror uploads to Storage; JSON credentials as single-line string)
FIREBASE_SERVICE_ACCOUNT_JSON=
FIREBASE_STORAGE_BUCKET=
